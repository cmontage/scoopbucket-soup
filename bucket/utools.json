{
    "version": "7.6.1",
    "homepage": "https://u.tools/",
    "description": "Your productive tools set and launcher.",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.6.1.exe#/uTools.7z",
            "hash": "0ec3822431bf97d7595397aab226b88dad75c2340ef515d6db7fe94ccd3c0501",
            "installer": {
                "script": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR/app-64.7z\" \"$dir\""
            }
        },
        "32bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.6.1-ia32.exe#/uTools.7z",
            "hash": "35e6e618fce39f6b21c08f613bfa901367a037347eba7a62c8fc0540414e1977",
            "installer": {
                "script": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR/app-32.7z\" \"$dir\""
            }
        }
    },
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:APPDATA\\uTools ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\uTools\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\`$R0\" -Force -Recurse",
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Confirm-Action",
        "Stop-App",
        "Write-Host (\"`nDeleting $env:APPDATA\\uTools ... \") -f DarkGray -NoNewline",
        "Remove-Junction \"$env:APPDATA\\uTools\" -ErrorAction SilentlyContinue | Out-Null"
    ],
    "shortcuts": [
        [
            "uTools.exe",
            "uTools"
        ]
    ],
    "checkver": {
        "url": "https://u.tools/download/",
        "regex": "uTools-(\\d+[\\.\\d]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version.exe#/uTools.7z"
            },
            "32bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version-ia32.exe#/uTools.7z"
            }
        }
    }
}
