{
    "version": "3.1.30.205130",
    "description": "网易云音乐客户端，发现好音乐。",
    "homepage": "https://music.163.com/",
    "license": {
        "identifier": "EULA",
        "url": "https://music.163.com/html/web2/service.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_3.1.30.205130_64.exe#/dl.7z",
            "hash": "9ae0f1fabc4286bc4121176d864b871e85c7b5bc24b40a41883dd19ecbe6aba5"
        },
        "32bit": {
            "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_3.1.30.205130_32.exe#/dl.7z",
            "hash": "b38e0448c75451c7f52799153197120a88322a09b080db1489e7917d73bf8ae9"
        }
    },
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Get-ChildItem \"$dir\\redist_packages\" | Move-Item -Destination \"$dir\" -Force",
        "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\redist_packages\" -Force -Recurse",
        "Remove-Item \"$dir\\*update*.exe\" -Force -ErrorAction SilentlyContinue",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:LOCALAPPDATA\\Netease\\CloudMusic ... \") -NoNewline",
        "New-PersistDirectory \"$env:LOCALAPPDATA\\Netease\\CloudMusic\" \"$persist_dir\\AppData\" -Migrate",
        "New-Item \"$dir\\downloads\" -Type Directory -Force -ErrorAction SilentlyContinue | Out-Null"
    ],
    "post_install": [
        "if (Test-Path \"$env:LOCALAPPDATA\\Netease\\CloudMusic\\update\") { Remove-Item \"$env:LOCALAPPDATA\\Netease\\CloudMusic\\update\" -Force -Recurse -ErrorAction SilentlyContinue }",
        "New-Item \"$env:LOCALAPPDATA\\Netease\\CloudMusic\\update\" -Type File -Force -ErrorAction SilentlyContinue | Out-Null"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Require-Admin",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        ". \"$bucketsdir\\$bucket\\scripts\\neteasemusic\\uninstall.ps1\""
    ],
    "bin": "cloudmusic.exe",
    "shortcuts": [
        [
            "cloudmusic.exe",
            "网易云音乐"
        ]
    ],
    "persist": "downloads",
    "checkver": {
        "url": "https://music.163.com/api/appcustomconfig/get",
        "jsonpath": "$.data.web-new-download.pc64.downloadUrl",
        "regex": "NeteaseCloudMusic_Music_official_([\\d.]+)_64.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_32.exe#/dl.7z"
            }
        }
    },
    "notes": [
        "User data is persisted in \"$persist_dir\".",
        "It is recommended to change NeteaseCloudMusic's default download directory to \"$persist_dir\\downloads\" and delete the original directory after migration."
    ]
}