{
    "version": "1.4.0",
    "description": "WeFlow - 一个本地的聊天导出和年度报告应用",
    "homepage": "https://github.com/hicccc77/WeFlow",
    "license": {
        "identifier": "Freeware",
        "url": "https://github.com/hicccc77/WeFlow/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hicccc77/WeFlow/releases/download/v1.4.0/WeFlow-1.4.0-Setup.exe#/dl.7z",
            "hash": "d4444e11f366695719ee135ce606b59f21a3fcd6a2034e8ef673b7c2fe667bca"
        }
    },
    "shortcuts": [
        [
            "WeFlow.exe",
            "WeFlow"
        ]
    ],
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse",
        "Write-Host (\"`nPersisting $env:APPDATA\\weflow ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\weflow\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Confirm-Action",
        "Stop-App",
        "Write-Host (\"`nDeleting $env:APPDATA\\weflow ... \") -f DarkGray -NoNewline",
        "Remove-Junction \"$env:APPDATA\\weflow\""
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hicccc77/WeFlow/releases/download/v$version/WeFlow-$version-Setup.exe#/dl.7z"
            }
        }
    }
}